{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"jsx": "react-jsx",
		"lib": ["es2022", "DOM", "DOM.Iterable"],
		"outDir": "dist"
	},
	"include": ["src"]
}
